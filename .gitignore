# =====================================================
#  Marvin — .gitignore
# =====================================================

# --- Secrets (NEVER commit) ---
.env
.env.local
.env.*.local
.envrc
*.pem
*.key
secrets/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- uv / pip ---
.uv/
pip-log.txt
pip-delete-this-directory.txt

# --- Testing / coverage ---
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# --- Type checkers ---
.mypy_cache/
.dmypy.json
.pyre/
.pytype/
.ruff_cache/

# --- Jupyter ---
.ipynb_checkpoints
*.ipynb_checkpoints/

# --- Marvin's data (machine-specific, huge, private) ---
data/
chromadb/
*.sqlite
*.sqlite3
*.db

# --- Local model weights (multi-GB) ---
models/
*.gguf
*.bin
*.safetensors
*.pt
*.pth

# --- Logs ---
logs/
*.log

# --- macOS junk ---
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes

# --- Editors / IDEs ---
.idea/
.vscode/
.cursor/
*.swp
*.swo
*~

# --- Node (if you ever add a frontend) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
